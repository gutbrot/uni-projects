    public void refresh()
    private void updateButtonState()
}
class Tile {
    public int x,y, width, height
    private int type
    List<Entity> entities = new ArrayList<>()
    public Tile(int type,int xPosition, int yPosition, int width, int height)

}
class World {
    private Tile[][] tiles
    public int rows
    public int cols
    public World(int rows, int cols)
    public MoveResult movePlayer(Character player, int dx, int dy)
}
class XmlMapLoader {
    public static void loadIntoModel(String path, Model model)
    public static World loadMap(Element root)
    private static void loadEnemies(Element root, World world)
    private static DependencyGraph loadAbilities(Element root)
}

GameEngine --- MenuFrame
GameEngine --- GameFrame
GameEngine --- GameCompletedFrame
GameEngine *-- Model

GameFrame --- GameCanvas
GameFrame --- CombatStatusPanel
GameFrame --- SkillPanel

Model o-- World
Model o-- Character
Model o-- DependencyGraph

Entity <|-- Character
Entity <|-- Monster

World *-- Entity
World *-- Tile
World --- MoveResult

DependencyGraph *--- Ability

Character *-- Item

MenuFrame --- XmlMapLoader
